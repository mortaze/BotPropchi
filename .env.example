# ─── دیتابیس ──────────────────────────────────────────────
# فرمت: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/propbot"

# ─── ربات تلگرام ──────────────────────────────────────────
# از @BotFather بگیرید
BOT_TOKEN="1234567890:AAF..."

# آیدی عددی ادمین اصلی (از @userinfobot بگیرید)
ADMIN_TELEGRAM_ID="123456789"

# ─── API مدیریت ───────────────────────────────────────────
JWT_SECRET="یک_رشته_تصادفی_طولانی_و_امن_بگذارید"
JWT_EXPIRES_IN="7d"
PORT=3000

# ─── محیط ─────────────────────────────────────────────────
NODE_ENV="development"

# ─── کش ───────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
