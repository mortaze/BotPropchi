PORT=3000

# ─── محیط ─────────────────────────────────────────────────
NODE_ENV="development"

# ─── کش ───────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ─── Redis (اختیاری — در صورت نبود از کش درون حافظه استفاده می‌کند)
REDIS_URL="redis://localhost:6379"

# ─── قرعه‌کشی ─────────────────────────────────────────────
WINNER_CONTACT="@MrKhodae"

# ─── عضویت اجباری ─────────────────────────────────────────
# مدت زمان کش شدن وضعیت عضویت هر کاربر در هر کانال (ثانیه)
MEMBERSHIP_CACHE_TTL=300

# لیست کانال‌های الزامی برای عضویت (با کاما جدا کنید)
# فقط آیدی عددی کانال — از @getidsbot بگیرید
# مثال: -1001234567890,-1009876543210
MEMBERSHIP_REQUIRED_CHANNELS=""

# نوع آپدیت‌هایی که ربات دریافت می‌کند (chat_member برای ردیابی لحظه‌ای)
# نیازی به تغییر نیست — ربات به‌صورت خودکار این را تنظیم می‌کند
