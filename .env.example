# آیدی عددی ادمین اصلی (از @userinfobot بگیرید)
ADMIN_TELEGRAM_ID="616991108"

# ─── API مدیریت ───────────────────────────────────────────
JWT_SECRET="8350406005:AAHT3Xf6ShlKleaEp-m_6jSLxA1oDZ43enw"
