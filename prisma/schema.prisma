  firstName         String?
  deletedByAdminId  Int
  deletedByAdminName String?
  deletedAt         DateTime @default(now())
  snapshot          Json
  reason            String?

  @@index([deletedUserId])
  @@index([telegramId])
  @@index([deletedAt])
  @@map("deleted_users_audit")
}

model UserEvent {
  id          Int      @id @default(autoincrement())
  userId      Int
  telegramId  BigInt
  eventType   String
  eventData   Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([telegramId])
  @@index([eventType])
  @@index([createdAt])
  @@map("user_events")
}

