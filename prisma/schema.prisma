generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////////
// USERS
////////////////////////////////////////////////////////////

model User {
  id             Int      @id @default(autoincrement())
  telegramId     BigInt   @unique
  username       String?
  firstName      String
  lastName       String?
  telegramFirstName String?
  telegramLastName  String?
  realFirstName     String?
  realLastName      String?
  phoneNumber    String?
  profileCompleted Boolean @default(false)
  points         Int      @default(0)
  totalReferrals Int      @default(0)
  isBlocked      Boolean  @default(false)
  membershipVerifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredById   Int?

  referredBy     User?      @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]     @relation("UserReferrals")
  sentReferrals  Referral[] @relation("ReferralReferrer")
  receivedReferral Referral? @relation("ReferralReferred")
  broadcastLogs  BroadcastLog[]
  pointLogs      PointLog[]
  lotteryEntries LotteryEntry[]
  lotteryWins    LotteryWinner[]
  clickLogs      ClickLog[]
  systemLogs     SystemLog[]
  miniAppDebugLogs MiniAppDebugLog[]
  aiChatLogs     AiChatLog[]
  requiredChannelMemberships UserRequiredChannelMembership[]
  referralLogsAsInviter ReferralLog[] @relation("ReferralLogInviter")
  referralLogsAsReferred ReferralLog[] @relation("ReferralLogReferred")

  @@index([referredById])
  @@index([profileCompleted])
  @@index([phoneNumber])
  @@map("users")
}

////////////////////////////////////////////////////////////
// PROP FIRMS
////////////////////////////////////////////////////////////

model PropFirm {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  slug          String   @unique
  description   String?
  logoUrl       String?
  websiteUrl    String?
  reviewLink    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  discountCodes DiscountCode[]

  @@map("prop_firms")
}

////////////////////////////////////////////////////////////
// DISCOUNT CODES
////////////////////////////////////////////////////////////

model DiscountCode {
  id              Int              @id @default(autoincrement())
  title           String
  code            String           @unique
  discountPercent Float
  affiliateLink   String?
  expiresAt       DateTime?
  isFeatured      Boolean          @default(false)
  isActive        Boolean          @default(true)
  usageCount      Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  propFirmId      Int

  propFirm PropFirm @relation(fields: [propFirmId], references: [id], onDelete: Cascade)
  clickLogs ClickLog[]

  @@map("discount_codes")
}

////////////////////////////////////////////////////////////
// POINTS
////////////////////////////////////////////////////////////

model PointLog {
  id          Int          @id @default(autoincrement())
  userId      Int
  amount      Int
  type        PointLogType
  description String?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("point_logs")
}

enum PointLogType {
  REFERRAL
  REFERRAL_REWARD
  DAILY_ACTIVITY
  LINK_CLICK
  AFFILIATE_PURCHASE
  LOTTERY_ENTRY
  ADMIN_GRANT
  PENALTY
  PROFILE_COMPLETION_REWARD
}


////////////////////////////////////////////////////////////
// REFERRALS
////////////////////////////////////////////////////////////

model Referral {
  id                         Int      @id @default(autoincrement())
  referrerId                 Int
  referredUserId             Int      @unique
  rewardPoints               Int
  membershipVerifiedAt       DateTime?
  membershipVerificationStatus String   @default("VERIFIED")
  createdAt                  DateTime @default(now())

  referrer     User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
  @@map("referrals")
}

////////////////////////////////////////////////////////////
// SEASONS
////////////////////////////////////////////////////////////

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(false)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referralLogs ReferralLog[]

  @@index([isActive])
  @@map("seasons")
}

////////////////////////////////////////////////////////////
// REFERRAL LOGS (IMMUTABLE — never update, never delete)
////////////////////////////////////////////////////////////

model ReferralLog {
  id         Int      @id @default(autoincrement())
  inviterId  Int
  referredId Int
  seasonId   Int
  createdAt  DateTime @default(now())

  inviter User   @relation("ReferralLogInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  referred User  @relation("ReferralLogReferred", fields: [referredId], references: [id], onDelete: Cascade)
  season  Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  @@index([inviterId])
  @@index([seasonId])
  @@index([inviterId, seasonId])
  @@index([createdAt])
  @@map("referral_logs")
}

model ReferralSettings {
  id                 Int      @id @default(1)
  inviteRewardPoints Int      @default(20)
  isEnabled          Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@map("referral_settings")
}

////////////////////////////////////////////////////////////
// LOTTERY
////////////////////////////////////////////////////////////

model Lottery {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  prize           String
  startAt         DateTime
  endAt           DateTime
  winnersCount    Int      @default(1)
  minPoints       Int      @default(0)
  entryCost       Int      @default(10)
  isActive        Boolean  @default(true)
  isCompleted     Boolean  @default(false)
  announcementMsg String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entries LotteryEntry[]
  winners LotteryWinner[]

  @@map("lotteries")
}

model LotteryEntry {
  id          Int      @id @default(autoincrement())
  userId      Int
  lotteryId   Int
  ticketCount Int      @default(1)
  pointsSpent Int      @default(0)
  chanceWeight Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)

  @@unique([userId, lotteryId])
  @@index([lotteryId])
  @@index([userId])
  @@index([lotteryId, ticketCount])
  @@map("lottery_entries")
}

model LotteryWinner {
  id               Int      @id @default(autoincrement())
  lotteryId        Int
  userId           Int
  prize            String
  winnerTelegramId BigInt
  winnerUsername   String?
  winnerFirstName  String
  winnerLastName   String?
  notified         Boolean  @default(false)
  prizeDelivered   Boolean  @default(false)
  wonAt            DateTime @default(now())

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@index([userId])
  @@map("lottery_winners")
}

////////////////////////////////////////////////////////////
// REQUIRED CHANNELS
////////////////////////////////////////////////////////////

model RequiredChannel {
  id         Int                     @id @default(autoincrement())
  channelId  String                  @unique
  chatId     String?
  title      String
  username   String?
  type       RequiredChannelType     @default(CHANNEL)
  inviteLink String?
  displayTitle String?
  buttonText String?
  botStatus String?
  botStatusCheckedAt DateTime?
  lastError String?
  status     RequiredChannelStatus   @default(APPROVED)
  isActive   Boolean                 @default(true)
  approvedAt DateTime?
  rejectedAt DateTime?
  disabledAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([isActive])
  @@index([status])
  @@index([type])
  memberships UserRequiredChannelMembership[]

  @@map("required_channels")
}

model UserRequiredChannelMembership {
  id                Int      @id @default(autoincrement())
  userId            Int
  requiredChannelId Int
  status            String
  verifiedAt        DateTime?
  lastCheckedAt     DateTime @default(now())
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  requiredChannel RequiredChannel @relation(fields: [requiredChannelId], references: [id], onDelete: Cascade)

  @@unique([userId, requiredChannelId])
  @@index([requiredChannelId, status])
  @@index([userId, status])
  @@map("user_required_channel_memberships")
}

enum RequiredChannelType {
  CHANNEL
  GROUP
}

enum RequiredChannelStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}


////////////////////////////////////////////////////////////
// BROADCASTS
////////////////////////////////////////////////////////////

model Broadcast {
  id             Int              @id @default(autoincrement())
  title          String
  messageType    BroadcastType    @default(TEXT)
  content        String?
  mediaFileId    String?
  mediaItems     Json?
  parseMode      BroadcastParseMode?
  inlineKeyboard Json?
  status         BroadcastStatus  @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalRecipients Int             @default(0)
  successCount   Int              @default(0)
  failedCount    Int              @default(0)
  createdBy      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  logs BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastLog {
  id          Int                @id @default(autoincrement())
  broadcastId Int
  userId      Int
  telegramId  BigInt
  status      BroadcastLogStatus @default(PENDING)
  attempts    Int                @default(0)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([broadcastId, status])
  @@index([telegramId])
  @@map("broadcast_logs")
}

enum BroadcastType {
  TEXT
  PHOTO
  VIDEO
  DOCUMENT
  VOICE
  AUDIO
  STICKER
  ANIMATION
  CONTACT
  LOCATION
  POLL
  MEDIA_GROUP
  COPY_MESSAGE
  FORWARD_MESSAGE
}

enum BroadcastParseMode {
  MARKDOWN
  HTML
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastLogStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

////////////////////////////////////////////////////////////
// CLICK LOGS
////////////////////////////////////////////////////////////

model ClickLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  discountCodeId Int
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@map("click_logs")
}

////////////////////////////////////////////////////////////
// GROUP MANAGEMENT
////////////////////////////////////////////////////////////

model TelegramGroup {
  id             Int                 @id @default(autoincrement())
  chatId         BigInt              @unique
  title          String
  username       String?
  status         TelegramGroupStatus @default(PENDING)
  botIsAdmin     Boolean             @default(false)
  botAdminCheckedAt DateTime?
  addedAt        DateTime            @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  disabledAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  keywordLogs    KeywordReplyLog[]

  @@index([status])
  @@index([botIsAdmin])
  @@map("telegram_groups")
}

enum TelegramGroupStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

////////////////////////////////////////////////////////////
// KEYWORD REPLIES
////////////////////////////////////////////////////////////

model KeywordReply {
  id          Int                       @id @default(autoincrement())
  keyword     String
  response    String?
  responseType KeywordReplyResponseType @default(TEXT)
  parseMode   BroadcastParseMode?
  mediaFileId String?
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  logs        KeywordReplyLog[]

  @@index([isActive])
  @@index([keyword])
  @@map("keyword_replies")
}

enum KeywordReplyResponseType {
  TEXT
  PHOTO
  DOCUMENT
}

model KeywordReplyLog {
  id              Int      @id @default(autoincrement())
  keywordReplyId  Int
  telegramGroupId Int
  userTelegramId  BigInt
  messageId       Int
  matchedText     String
  createdAt       DateTime @default(now())

  keywordReply  KeywordReply  @relation(fields: [keywordReplyId], references: [id], onDelete: Cascade)
  telegramGroup TelegramGroup @relation(fields: [telegramGroupId], references: [id], onDelete: Cascade)

  @@index([keywordReplyId])
  @@index([telegramGroupId])
  @@index([createdAt])
  @@map("keyword_reply_logs")
}


////////////////////////////////////////////////////////////
// BOT ADMINS
////////////////////////////////////////////////////////////

model BotAdmin {
  id         Int            @id @default(autoincrement())
  telegramId BigInt         @unique
  username   String?
  firstName  String?
  lastName   String?
  role       BotAdminRole   @default(ADMIN)
  status     BotAdminStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([role])
  @@map("bot_admins")
}

enum BotAdminRole {
  OWNER
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum BotAdminStatus {
  ACTIVE
  SUSPENDED
}

////////////////////////////////////////////////////////////
// SYSTEM LOGS
////////////////////////////////////////////////////////////

model MiniAppDebugLog {
  id         Int      @id @default(autoincrement())
  telegramId BigInt?
  eventType  String
  message    String
  payload    Json?
  userAgent  String?
  createdAt  DateTime @default(now())
  userId     Int?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([telegramId])
  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("mini_app_debug_logs")
}

model SystemLog {
  id             Int            @id @default(autoincrement())
  eventType      SystemEventType
  level          SystemLogLevel  @default(INFO)
  message        String
  userId         Int?
  telegramId     BigInt?
  metadata       Json?
  createdAt      DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([level])
  @@index([userId])
  @@index([telegramId])
  @@index([createdAt])
  @@map("system_logs")
}

enum SystemEventType {
  USER_LOGIN
  FORCE_JOIN
  REFERRAL
  BROADCAST
  LOTTERY
  DISCOUNT_CLICK
  ERROR
  ADMIN_ACTION
  GROUP_INTEGRATION
  USER_PROFILE_COMPLETED
  USER_PROFILE_UPDATED
  AI_CHAT
}

enum SystemLogLevel {
  INFO
  WARN
  ERROR
}

////////////////////////////////////////////////////////////
// ADMINS
////////////////////////////////////////////////////////////

model Admin {
  id           Int       @id @default(autoincrement())
  firstName    String?
  lastName     String?
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  OWNER
}


model ScoringSettings {
  id                      Int      @id @default(1)
  startPoints             Int      @default(0)
  channelJoinPoints       Int      @default(0)
  futureActivityPoints    Int      @default(0)
  dailyActivityPoints     Int      @default(5)
  linkClickPoints         Int      @default(2)
  referralRewardPoints    Int      @default(20)
  profileCompletionPoints Int      @default(50)
  welcomeMessageText      String   @default("سلام {name} عزیز! 👋\n\n🎯 به ربات کدهای تخفیف پراپ فرم خوش آمدید\n\nاز منوی زیر انتخاب کنید:")
  initialPointsMessageText String  @default("🎁 {points} امتیاز اولیه به حساب شما اضافه شد.")
  isWelcomeMessageEnabled Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("scoring_settings")
}

model AiSettings {
  id                   Int      @id @default(1)
  systemPrompt         String   @default("تو یک دستیار تخصصی فارسی‌زبان در حوزه پراپ فرم‌ها هستی. فقط درباره پراپ فرم‌ها، قوانین حساب‌ها، قوانین تریدینگ و کدهای تخفیف پاسخ بده.")
  allowedSourceUrls    Json     @default("[]")
  fallbackMessage      String   @default("این سوال خارج از محدوده سیستم است.")
  topicFallbackMessage String   @default("⚠️ این دستیار فقط برای سوالات مربوط به پراپ فرم‌ها و کدهای تخفیف فعال است.")
  sourceFallbackMessage String  @default("اطلاعات این موضوع در منابع معتبر پراپ هاب موجود نیست.")
  model                String   @default("gemini-2.5-flash")
  rateLimitPerHour     Int      @default(20)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("ai_settings")
}

model AiApiKey {
  id         Int      @id @default(autoincrement())
  name       String?
  apiKey     String
  keyPreview String
  isActive   Boolean  @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chatLogs AiChatLog[]

  @@index([isActive])
  @@map("ai_api_keys")
}

model AiChatLog {
  id         Int          @id @default(autoincrement())
  userId     Int?
  telegramId BigInt?
  message    String
  response   String?
  status     AiChatStatus @default(SUCCESS)
  source     String       @default("API")
  error      String?
  aiApiKeyId Int?
  createdAt  DateTime     @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  aiApiKey AiApiKey? @relation(fields: [aiApiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([telegramId])
  @@index([status])
  @@index([createdAt])
  @@map("ai_chat_logs")
}

enum AiChatStatus {
  SUCCESS
  REJECTED_TOPIC
  BLOCKED_INJECTION
  RATE_LIMITED
  ERROR
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model ForcedMembershipSettings {
  id                Int      @id @default(1)
  enabled           Boolean  @default(true)
  channelId         String   @default("")
  notJoinedMessage  String   @default("⚠️ برای استفاده از ربات باید ابتدا در کانال زیر عضو شوید.")
  leaveWarningMessage String @default("❌ شما کانال را ترک کردید. لطفاً دوباره عضو شوید.")
  helpMessage       String   @default("برای استفاده از ربات باید عضو کانال ما باشید.\n\nلطفاً در کانال زیر عضو شده و دکمه بررسی را بزنید.")
  joinButtonText    String   @default("عضویت در کانال")
  checkButtonText   String   @default("✅ عضو شدم، بررسی کن")
  instructionText   String   @default("لطفاً در کانال(های) زیر عضو شده و دکمه بررسی را بزنید.")
  welcomeBackMessage String  @default("✅ خوش آمدید! عضویت شما تایید شد و اکنون می‌توانید از ربات استفاده کنید.")
  checkingMessage   String   @default("در حال بررسی عضویت شما...")
  verifiedMessage   String   @default("✅ عضویت شما تایید شد. حالا می‌توانید از امکانات ربات استفاده کنید.")
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@map("forced_membership_settings")
}


model ForceJoinSettings {
  id                          Int      @id @default(1)
  title                       String   @default("عضویت اجباری")
  welcomeMessage              String   @default("برای استفاده از ربات ابتدا در کانال‌های زیر عضو شوید")
  notJoinedMessage            String   @default("هنوز در همه کانال‌ها عضو نشده‌اید")
  joinButtonText              String   @default("عضویت")
  checkMembershipButtonText   String   @default("بررسی عضویت")
  successJoinMessage          String   @default("عضویت شما تایید شد ✅")
  errorMessage                String   @default("خطا در بررسی عضویت")
  retryMessage                String   @default("دوباره تلاش کنید")
  emptyChannelsMessage        String   @default("فعلاً کانالی تعریف نشده است")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("force_join_settings")
}

model MenuOrder {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  href      String
  order     Int
  isActive  Boolean  @default(true)
  ownerOnly Boolean  @default(false)
  featureKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("menu_orders")
}

model FeatureToggle {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  description String?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_toggles")
}

////////////////////////////////////////////////////////////
// POSTS / CMS
////////////////////////////////////////////////////////////

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
  HIDDEN
}

enum PostButtonType {
  URL
  CALLBACK
  OPEN_MINI_APP
  OPEN_WEB
  COPY_TEXT
  SEND_COMMAND
  INTERNAL_NAV
}

model Post {
  id            Int        @id @default(autoincrement())
  title         String
  slug          String     @unique
  content       String?
  caption       String?
  mediaFileId   String?
  mediaType     String?
  albumMediaIds Json?
  parseMode     String?    @default("Markdown")
  buttons       Json?
  command       String?
  isPublished   Boolean    @default(false)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  unpublishAt   DateTime?
  sortOrder     Int        @default(0)
  status        PostStatus @default(DRAFT)
  rawContent    String?
  renderedContent String?
  createdBy     BigInt?
  updatedBy     BigInt?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  views      PostView[]
  commands   PostCommand[]
  clickLogs  PostClickLog[]
  postButtons PostButton[]
  versions   PostVersion[]

  @@index([status])
  @@index([isPublished])
  @@index([slug])
  @@index([sortOrder])
  @@map("posts")
}

model PostButton {
  id        Int            @id @default(autoincrement())
  postId    Int
  row       Int            @default(0)
  col       Int            @default(0)
  text      String
  type      PostButtonType @default(URL)
  value     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_buttons")
}

model PostCommand {
  id        Int      @id @default(autoincrement())
  postId    Int
  command   String   @unique
  aliases   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([command])
  @@map("post_commands")
}

model PostView {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int?
  telegramId BigInt?
  action    String   @default("view")
  metadata  Json?
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("post_views")
}

model PostClickLog {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int?
  telegramId BigInt?
  buttonText String?
  buttonType String?
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_click_logs")
}

model PostVersion {
  id        Int      @id @default(autoincrement())
  postId    Int
  snapshot  Json
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
  @@map("post_versions")
}
