generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////////
// USERS
////////////////////////////////////////////////////////////

model User {
  id             Int      @id @default(autoincrement())
  telegramId     BigInt   @unique
  username       String?
  firstName      String
  lastName       String?
  points         Int      @default(0)
  totalReferrals Int      @default(0)
  isBlocked      Boolean  @default(false)
  lastActiveAt   DateTime @default(now())
  membershipVerifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredById   Int?

  referredBy     User?      @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]     @relation("UserReferrals")
  sentReferrals  Referral[] @relation("ReferralReferrer")
  receivedReferral Referral? @relation("ReferralReferred")
  broadcastLogs  BroadcastLog[]
  pointLogs      PointLog[]
  lotteryEntries LotteryEntry[]
  lotteryWins    LotteryWinner[]
  clickLogs      ClickLog[]
  systemLogs     SystemLog[]
  requiredChannelMemberships UserRequiredChannelMembership[]

  @@index([referredById])
  @@map("users")
}

////////////////////////////////////////////////////////////
// PROP FIRMS
////////////////////////////////////////////////////////////

model PropFirm {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  slug          String   @unique
  description   String?
  logoUrl       String?
  websiteUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  discountCodes DiscountCode[]

  @@map("prop_firms")
}

////////////////////////////////////////////////////////////
// DISCOUNT CODES
////////////////////////////////////////////////////////////

model DiscountCode {
  id              Int              @id @default(autoincrement())
  title           String
  code            String           @unique
  discountPercent Float
  affiliateLink   String?
  expiresAt       DateTime?
  isFeatured      Boolean          @default(false)
  isActive        Boolean          @default(true)
  usageCount      Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  propFirmId      Int

  propFirm PropFirm @relation(fields: [propFirmId], references: [id], onDelete: Cascade)
  clickLogs ClickLog[]

  @@map("discount_codes")
}

////////////////////////////////////////////////////////////
// POINTS
////////////////////////////////////////////////////////////

model PointLog {
  id          Int          @id @default(autoincrement())
  userId      Int
  amount      Int
  type        PointLogType
  description String?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("point_logs")
}

enum PointLogType {
  REFERRAL
  REFERRAL_REWARD
  DAILY_ACTIVITY
  LINK_CLICK
  AFFILIATE_PURCHASE
  LOTTERY_ENTRY
  ADMIN_GRANT
  PENALTY
}


////////////////////////////////////////////////////////////
// REFERRALS
////////////////////////////////////////////////////////////

model Referral {
  id                         Int      @id @default(autoincrement())
  referrerId                 Int
  referredUserId             Int      @unique
  rewardPoints               Int
  membershipVerifiedAt       DateTime?
  membershipVerificationStatus String   @default("VERIFIED")
  createdAt                  DateTime @default(now())

  referrer     User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
  @@map("referrals")
}

model ReferralSettings {
  id                 Int      @id @default(1)
  inviteRewardPoints Int      @default(20)
  isEnabled          Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@map("referral_settings")
}

////////////////////////////////////////////////////////////
// LOTTERY
////////////////////////////////////////////////////////////

model Lottery {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  prize           String
  startAt         DateTime
  endAt           DateTime
  winnersCount    Int      @default(1)
  minPoints       Int      @default(0)
  entryCost       Int      @default(10)
  isActive        Boolean  @default(true)
  isCompleted     Boolean  @default(false)
  announcementMsg String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entries LotteryEntry[]
  winners LotteryWinner[]

  @@map("lotteries")
}

model LotteryEntry {
  id          Int      @id @default(autoincrement())
  userId      Int
  lotteryId   Int
  ticketCount Int      @default(1)
  pointsSpent Int      @default(0)
  chanceWeight Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)

  @@unique([userId, lotteryId])
  @@index([lotteryId])
  @@index([userId])
  @@index([lotteryId, ticketCount])
  @@map("lottery_entries")
}

model LotteryWinner {
  id               Int      @id @default(autoincrement())
  lotteryId        Int
  userId           Int
  prize            String
  winnerTelegramId BigInt
  winnerUsername   String?
  winnerFirstName  String
  winnerLastName   String?
  notified         Boolean  @default(false)
  prizeDelivered   Boolean  @default(false)
  wonAt            DateTime @default(now())

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@index([userId])
  @@map("lottery_winners")
}

////////////////////////////////////////////////////////////
// REQUIRED CHANNELS
////////////////////////////////////////////////////////////

model RequiredChannel {
  id         Int                     @id @default(autoincrement())
  channelId  String                  @unique
  chatId     String?
  title      String
  username   String?
  type       RequiredChannelType     @default(CHANNEL)
  inviteLink String?
  displayTitle String?
  buttonText String?
  botStatus String?
  botStatusCheckedAt DateTime?
  lastError String?
  status     RequiredChannelStatus   @default(APPROVED)
  isActive   Boolean                 @default(true)
  approvedAt DateTime?
  rejectedAt DateTime?
  disabledAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([isActive])
  @@index([status])
  @@index([type])
  memberships UserRequiredChannelMembership[]

  @@map("required_channels")
}

model UserRequiredChannelMembership {
  id                Int      @id @default(autoincrement())
  userId            Int
  requiredChannelId Int
  status            String
  verifiedAt        DateTime?
  lastCheckedAt     DateTime @default(now())
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  requiredChannel RequiredChannel @relation(fields: [requiredChannelId], references: [id], onDelete: Cascade)

  @@unique([userId, requiredChannelId])
  @@index([requiredChannelId, status])
  @@index([userId, status])
  @@map("user_required_channel_memberships")
}

enum RequiredChannelType {
  CHANNEL
  GROUP
}

enum RequiredChannelStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}


////////////////////////////////////////////////////////////
// BROADCASTS
////////////////////////////////////////////////////////////

model Broadcast {
  id             Int              @id @default(autoincrement())
  title          String
  messageType    BroadcastType    @default(TEXT)
  content        String?
  mediaFileId    String?
  mediaItems     Json?
  parseMode      BroadcastParseMode?
  inlineKeyboard Json?
  status         BroadcastStatus  @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalRecipients Int             @default(0)
  successCount   Int              @default(0)
  failedCount    Int              @default(0)
  createdBy      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  logs BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastLog {
  id          Int                @id @default(autoincrement())
  broadcastId Int
  userId      Int
  telegramId  BigInt
  status      BroadcastLogStatus @default(PENDING)
  attempts    Int                @default(0)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([broadcastId, status])
  @@index([telegramId])
  @@map("broadcast_logs")
}

enum BroadcastType {
  TEXT
  PHOTO
  VIDEO
  DOCUMENT
  VOICE
  AUDIO
  STICKER
  ANIMATION
  MEDIA_GROUP
  COPY_MESSAGE
}

enum BroadcastParseMode {
  MARKDOWN
  HTML
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastLogStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

////////////////////////////////////////////////////////////
// CLICK LOGS
////////////////////////////////////////////////////////////

model ClickLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  discountCodeId Int
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@map("click_logs")
}

////////////////////////////////////////////////////////////
// GROUP MANAGEMENT
////////////////////////////////////////////////////////////

model TelegramGroup {
  id             Int                 @id @default(autoincrement())
  chatId         BigInt              @unique
  title          String
  username       String?
  status         TelegramGroupStatus @default(PENDING)
  botIsAdmin     Boolean             @default(false)
  botAdminCheckedAt DateTime?
  addedAt        DateTime            @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  disabledAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  keywordLogs    KeywordReplyLog[]

  @@index([status])
  @@index([botIsAdmin])
  @@map("telegram_groups")
}

enum TelegramGroupStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

////////////////////////////////////////////////////////////
// KEYWORD REPLIES
////////////////////////////////////////////////////////////

model KeywordReply {
  id          Int                       @id @default(autoincrement())
  keyword     String
  response    String?
  responseType KeywordReplyResponseType @default(TEXT)
  parseMode   BroadcastParseMode?
  mediaFileId String?
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  logs        KeywordReplyLog[]

  @@index([isActive])
  @@index([keyword])
  @@map("keyword_replies")
}

enum KeywordReplyResponseType {
  TEXT
  PHOTO
  DOCUMENT
}

model KeywordReplyLog {
  id              Int      @id @default(autoincrement())
  keywordReplyId  Int
  telegramGroupId Int
  userTelegramId  BigInt
  messageId       Int
  matchedText     String
  createdAt       DateTime @default(now())

  keywordReply  KeywordReply  @relation(fields: [keywordReplyId], references: [id], onDelete: Cascade)
  telegramGroup TelegramGroup @relation(fields: [telegramGroupId], references: [id], onDelete: Cascade)

  @@index([keywordReplyId])
  @@index([telegramGroupId])
  @@index([createdAt])
  @@map("keyword_reply_logs")
}


////////////////////////////////////////////////////////////
// BOT ADMINS
////////////////////////////////////////////////////////////

model BotAdmin {
  id         Int            @id @default(autoincrement())
  telegramId BigInt         @unique
  username   String?
  firstName  String?
  lastName   String?
  role       BotAdminRole   @default(ADMIN)
  status     BotAdminStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([role])
  @@map("bot_admins")
}

enum BotAdminRole {
  OWNER
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum BotAdminStatus {
  ACTIVE
  SUSPENDED
}

////////////////////////////////////////////////////////////
// SYSTEM LOGS
////////////////////////////////////////////////////////////

model SystemLog {
  id             Int            @id @default(autoincrement())
  eventType      SystemEventType
  level          SystemLogLevel  @default(INFO)
  message        String
  userId         Int?
  telegramId     BigInt?
  metadata       Json?
  createdAt      DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([level])
  @@index([userId])
  @@index([telegramId])
  @@index([createdAt])
  @@map("system_logs")
}

enum SystemEventType {
  USER_LOGIN
  FORCE_JOIN
  REFERRAL
  BROADCAST
  LOTTERY
  DISCOUNT_CLICK
  ERROR
  ADMIN_ACTION
  GROUP_INTEGRATION
}

enum SystemLogLevel {
  INFO
  WARN
  ERROR
}

////////////////////////////////////////////////////////////
// ADMINS
////////////////////////////////////////////////////////////

model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(MODERATOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}
