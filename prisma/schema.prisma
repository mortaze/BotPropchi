enum TicketStatus {
  OPEN
  CLOSED
  DELETED
}

enum TicketSenderType {
  USER
  ADMIN
}

enum TicketMessageType {
  TEXT
  PHOTO
  VIDEO
  VOICE
  AUDIO
  DOCUMENT
  STICKER
  MEDIA_GROUP
}

model TicketCategory {
  id        Int       @id @default(autoincrement())
  title     String
  enabled   Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tickets   Ticket[]

  @@index([enabled])
  @@index([order])
  @@map("ticket_categories")
}

model Ticket {
  id          Int              @id @default(autoincrement())
  userId      Int
  categoryId  Int
  status      TicketStatus     @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  closedAt    DateTime?
  deletedAt   DateTime?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    TicketCategory   @relation(fields: [categoryId], references: [id])
  messages    TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id             Int                @id @default(autoincrement())
  ticketId       Int
  senderType     TicketSenderType
  messageType    TicketMessageType  @default(TEXT)
  text           String?
  fileId         String?
  fileUniqueId   String?
  mimeType       String?
  fileSize       Int?
  isRead         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  ticket         Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  attachments    TicketAttachment[]

  @@index([ticketId])
  @@index([senderType])
  @@index([isRead])
  @@map("ticket_messages")
}

model TicketAttachment {
  id              Int           @id @default(autoincrement())
  messageId       Int
  telegramFileId  String
  type            String
  metadata        Json?
  createdAt       DateTime      @default(now())
  message         TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("ticket_attachments")
}

// ─── Scheduled Messages (پیام‌های خودکار) ────────────────────

model ScheduledMessage {
  id            Int                @id @default(autoincrement())
  title         String
  slug          String?            @unique
  status        PostStatus         @default(DRAFT)
  isPublished   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  intervalMinutes Int?
  startTime     String?
  targetChatId  BigInt?
  targetTopicId BigInt?
  lastSentAt    DateTime?
  nextSendAt    DateTime?
  sendCount     Int                @default(0)
  createdBy     BigInt?

  messages      ScheduledMessageMessage[]
  buttons       ScheduledMessageButton[]
  logs          ScheduledPostLog[]

  @@index([status])
  @@index([nextSendAt])
  @@index([isPublished])
  @@map("scheduled_messages")
}

model ScheduledMessageMessage {
  id                 Int               @id @default(autoincrement())
  scheduledMessageId Int
  text               String            @default("")
  type               PostMessageType   @default(text)
  order              Int               @default(0)
  mediaFileId        String?
  caption            String?
  captionEntities    Json?
  entities           Json?
  replyMarkup        Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  scheduledMessage   ScheduledMessage  @relation(fields: [scheduledMessageId], references: [id], onDelete: Cascade)
  buttons            ScheduledMessageButton[]

  @@index([scheduledMessageId, order])
  @@map("scheduled_message_messages")
}

model ScheduledMessageButton {
  id                 Int                  @id @default(autoincrement())
  scheduledMessageId Int
  messageId          Int?
  row                Int                  @default(0)
  col                Int                  @default(0)
  text               String
  type               String               @default("URL")
  value              String?
  style              String?
  payload            Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  scheduledMessage   ScheduledMessage     @relation(fields: [scheduledMessageId], references: [id], onDelete: Cascade)
  message            ScheduledMessageMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([scheduledMessageId])
  @@index([messageId])
  @@map("scheduled_message_buttons")
}

model ScheduledPostLog {
  id                 Int               @id @default(autoincrement())
  scheduledMessageId Int
  sentAt             DateTime          @default(now())
  targetChatId       BigInt
  targetTopicId      BigInt?
  status             String            @default("SUCCESS")
  errorMessage       String?
  createdAt          DateTime          @default(now())
  scheduledMessage   ScheduledMessage  @relation(fields: [scheduledMessageId], references: [id], onDelete: Cascade)

  @@index([scheduledMessageId])
  @@index([sentAt])
  @@map("scheduled_post_logs")
}

// ─── Forum Topics (discovered from Telegram updates) ──────

model ForumTopic {
  id            Int      @id @default(autoincrement())
  chatId        BigInt
  topicId       Int
  name          String
  isClosed      Boolean  @default(false)
  isHidden      Boolean  @default(false)
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chatId, topicId])
  @@index([chatId])
  @@map("forum_topics")
}
