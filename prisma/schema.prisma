generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         Int                             @id @default(autoincrement())
  telegramId                 BigInt                          @unique
  username                   String?
  firstName                  String
  lastName                   String?
  languageCode               String?
  points                     Int                             @default(0)
  totalReferrals             Int                             @default(0)
  isBlocked                  Boolean                         @default(false)
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt
  referredById               Int?
  membershipVerifiedAt       DateTime?
  phoneNumber                String?
  profileCompleted           Boolean                         @default(false)
  realFirstName              String?
  realLastName               String?
  telegramFirstName          String?
  telegramLastName           String?
  acquisitionSource          String?
  startPayload               String?
  referrerUserId             Int?
  utmSource                  String?
  utmCampaign                String?
  lastActivityAt             DateTime?
  firstActivityAt            DateTime?
  firstStartPayload          String?
  startCount                 Int                             @default(0)
  activeDaysCount            Int                             @default(0)
  messagesSentCount          Int                             @default(0)
  activitiesCount            Int                             @default(0)
  successfulReferrals        Int                             @default(0)
  lastDeviceType             String?
  attributionConfidence      Int                             @default(0)
  attribution                UserAttribution?
  broadcastLogs              BroadcastLog[]
  leaderboardCacheEntries    LeaderboardCache[]              @relation("LeaderboardCacheUser")
  lotteryEntries             LotteryEntry[]
  lotteryWins                LotteryWinner[]
  winnerNotifications        WinnerNotification[]
  miniAppDebugLogs           MiniAppDebugLog[]
  pointLogs                  PointLog[]
  referralLogsAsInviter      ReferralLog[]                   @relation("ReferralLogInviter")
  referralLogsAsReferred     ReferralLog[]                   @relation("ReferralLogReferred")
  receivedReferral           Referral?                       @relation("ReferralReferred")
  sentReferrals              Referral[]                      @relation("ReferralReferrer")
  systemLogs                 SystemLog[]
  requiredChannelMemberships UserRequiredChannelMembership[]
  referredBy                 User?                           @relation("UserReferrals", fields: [referredById], references: [id])
  referrals                  User[]                          @relation("UserReferrals")
  attributionEvents          AttributionEvent[]
  userEvents                 UserEvent[]
  userMessageHistory         UserMessageHistory[]
  tickets                    Ticket[]

  @@index([referredById])
  @@index([profileCompleted])
  @@index([phoneNumber])
  @@index([acquisitionSource])
  @@index([lastActivityAt])
  @@index([attributionConfidence])
  @@map("users")
}

model UserAttribution {
  id                         Int                             @id @default(autoincrement())
  userId                     Int                             @unique
  telegramId                 BigInt                          @unique
  startedAt                  DateTime?
  firstSeenAt                DateTime?
  firstStartPayload          String?
  acquisitionSource          String                          @default("direct")
  referralCode               String?
  inviterUserId              Int?
  campaignId                 String?
  inviteLinkId               String?
  deepLinkPayload            String?
  registrationDate           DateTime?
  firstActivityAt            DateTime?
  lastActivityAt             DateTime?
  startCount                 Int                             @default(0)
  activeDaysCount            Int                             @default(0)
  messagesSentCount          Int                             @default(0)
  activitiesCount            Int                             @default(0)
  successfulReferrals        Int                             @default(0)
  lastDeviceType             String?
  confidenceScore            Int                             @default(0)
  confidenceFlags            Json?
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt
  user                       User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events                     AttributionEvent[]

  @@index([acquisitionSource])
  @@index([inviterUserId])
  @@index([confidenceScore])
  @@index([startedAt])
  @@map("user_attributions")
}

model AttributionEvent {
  id                         Int                             @id @default(autoincrement())
  userId                     Int
  attributionId              Int?
  eventType                  String
  payload                    Json?
  source                     String?
  referralCode               String?
  inviterUserId              Int?
  campaignId                 String?
  sessionId                  String?
  confidenceContribution     Int?
  createdAt                  DateTime                        @default(now())
  user                       User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribution                UserAttribution?                @relation(fields: [attributionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("attribution_events")
}

model PointLog {
  id          Int          @id @default(autoincrement())
  userId      Int
  amount      Int
  type        PointLogType
  description String?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("point_logs")
}

model Referral {
  id                           Int       @id @default(autoincrement())
  referrerId                   Int
  referredUserId               Int       @unique
  rewardPoints                 Int
  createdAt                    DateTime  @default(now())
  membershipVerificationStatus String    @default("VERIFIED")
  membershipVerifiedAt         DateTime?
  referredUser                 User      @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer                     User      @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
  @@map("referrals")
}

model Season {
  id                      Int                @id @default(autoincrement())
  name                    String
  isActive                Boolean            @default(false)
  startDate               DateTime
  endDate                 DateTime
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  leaderboardCacheEntries LeaderboardCache[] @relation("LeaderboardCacheSeason")
  referralLogs            ReferralLog[]

  @@index([isActive])
  @@map("seasons")
}

model LeaderboardCache {
  id        Int      @id @default(autoincrement())
  userId    Int
  seasonId  Int
  score     Int      @default(0)
  updatedAt DateTime @updatedAt
  season    Season   @relation("LeaderboardCacheSeason", fields: [seasonId], references: [id])
  user      User     @relation("LeaderboardCacheUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, score])
  @@map("leaderboard_cache")
}

model ReferralLog {
  id         Int      @id @default(autoincrement())
  inviterId  Int
  referredId Int
  seasonId   Int
  createdAt  DateTime @default(now())
  inviter    User     @relation("ReferralLogInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  referred   User     @relation("ReferralLogReferred", fields: [referredId], references: [id], onDelete: Cascade)
  season     Season   @relation(fields: [seasonId], references: [id])

  @@index([inviterId])
  @@index([seasonId])
  @@index([inviterId, seasonId])
  @@index([createdAt])
  @@map("referral_logs")
}

model ReferralSettings {
  id                 Int      @id @default(1)
  inviteRewardPoints Int      @default(20)
  isEnabled          Boolean  @default(true)
  referralShareText  String   @default("این ربات بیشتر کد تخفیف پراپ فرم دارم استارش کن 👇")
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@map("referral_settings")
}

model Lottery {
  id              Int                 @id @default(autoincrement())
  title           String
  description     String?
  prize           String
  startAt         DateTime?
  endAt           DateTime?
  winnersCount    Int                 @default(1)
  minPoints       Int                 @default(0)
  isActive        Boolean             @default(true)
  isCompleted     Boolean             @default(false)
  announcementMsg String?
  winnerMessage   String?             @default("تبریک 🎉\nشما برنده قرعه‌کشی شدید.\nبرای دریافت جایزه با پشتیبانی تماس بگیرید.")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  entryCost       Int                 @default(10)
  entries         LotteryEntry[]
  winners         LotteryWinner[]
  notifications   WinnerNotification[]

  @@map("lotteries")
}

model LotteryEntry {
  id           Int      @id @default(autoincrement())
  userId       Int
  lotteryId    Int
  createdAt    DateTime @default(now())
  chanceWeight Int      @default(1)
  pointsSpent  Int      @default(0)
  ticketCount  Int      @default(1)
  updatedAt    DateTime @updatedAt
  lottery      Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lotteryId])
  @@index([lotteryId])
  @@index([userId])
  @@index([lotteryId, ticketCount])
  @@map("lottery_entries")
}

model LotteryWinner {
  id               Int      @id @default(autoincrement())
  lotteryId        Int
  userId           Int
  prize            String
  winnerTelegramId BigInt
  winnerUsername   String?
  winnerFirstName  String
  winnerLastName   String?
  notified         Boolean  @default(false)
  prizeDelivered   Boolean  @default(false)
  roundNumber      Int      @default(1)
  wonAt            DateTime @default(now())
  lottery          Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@index([userId])
  @@map("lottery_winners")
}

model WinnerNotification {
  id         Int      @id @default(autoincrement())
  lotteryId  Int
  userId     Int
  sentAt     DateTime @default(now())
  status     String   @default("PENDING")
  lottery    Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@index([userId])
  @@map("winner_notifications")
}

model RequiredChannel {
  id                 Int                             @id @default(autoincrement())
  channelId          String                          @unique
  title              String
  inviteLink         String?
  isActive           Boolean                         @default(true)
  createdAt          DateTime                        @default(now())
  chatId             String?
  type               RequiredChannelType             @default(CHANNEL)
  updatedAt          DateTime                        @updatedAt
  username           String?
  approvedAt         DateTime?
  disabledAt         DateTime?
  rejectedAt         DateTime?
  status             RequiredChannelStatus           @default(APPROVED)
  botStatus          String?
  botStatusCheckedAt DateTime?
  buttonText         String?
  displayTitle       String?
  lastError          String?
  memberships        UserRequiredChannelMembership[]

  @@index([isActive])
  @@index([status])
  @@index([type])
  @@map("required_channels")
}

model UserRequiredChannelMembership {
  id                Int             @id @default(autoincrement())
  userId            Int
  requiredChannelId Int
  status            String
  verifiedAt        DateTime?
  lastCheckedAt     DateTime        @default(now())
  error             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  requiredChannel   RequiredChannel @relation(fields: [requiredChannelId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, requiredChannelId])
  @@index([requiredChannelId, status])
  @@index([userId, status])
  @@map("user_required_channel_memberships")
}

model Broadcast {
  id              Int                 @id @default(autoincrement())
  title           String
  messageType     BroadcastType       @default(TEXT)
  content         String?
  mediaFileId     String?
  mediaItems      Json?
  parseMode       BroadcastParseMode?
  inlineKeyboard  Json?
  status          BroadcastStatus     @default(DRAFT)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  totalRecipients Int                 @default(0)
  successCount    Int                 @default(0)
  failedCount     Int                 @default(0)
  createdBy       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  logs            BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastLog {
  id          Int                @id @default(autoincrement())
  broadcastId Int
  userId      Int
  telegramId  BigInt
  status      BroadcastLogStatus @default(PENDING)
  attempts    Int                @default(0)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  broadcast   Broadcast          @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryLog BroadcastDeliveryLog?

  @@unique([broadcastId, userId])
  @@index([broadcastId, status])
  @@index([telegramId])
  @@map("broadcast_logs")
}

model BroadcastDeliveryLog {
  id                    Int       @id @default(autoincrement())
  broadcastId           Int
  broadcastLogId        Int       @unique
  userId                Int
  telegramUserId        BigInt
  chatId                String?
  username              String?
  attemptedAt           DateTime?
  finalStatus           String
  rawTelegramResponse   Json?
  errorMessage          String?
  httpStatusCode        Int?
  telegramErrorCode    Int?
  telegramDescription   String?
  responseTimeMs        Int?
  retryCount            Int       @default(0)
  botVersion            String?
  serverName            String?
  jobId                 String?
  correlationId         String?
  errorCategory         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  broadcastLog          BroadcastLog @relation(fields: [broadcastLogId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([errorCategory])
  @@index([finalStatus])
  @@index([userId])
  @@index([createdAt])
  @@map("broadcast_delivery_logs")
}

model TelegramGroup {
  id                   Int                 @id @default(autoincrement())
  chatId               BigInt              @unique
  title                String
  username             String?
  status               TelegramGroupStatus @default(PENDING)
  botIsAdmin           Boolean             @default(false)
  botAdminCheckedAt    DateTime?
  addedAt              DateTime            @default(now())
  approvedAt           DateTime?
  rejectedAt           DateTime?
  disabledAt           DateTime?
  isForum              Boolean             @default(false)
  forumTopics          Json?
  forumTopicsFetchedAt DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  keywordLogs          KeywordReplyLog[]

  @@index([status])
  @@index([botIsAdmin])
  @@map("telegram_groups")
}

model KeywordReply {
  id           Int                      @id @default(autoincrement())
  keyword      String
  response     String?
  responseType KeywordReplyResponseType @default(TEXT)
  parseMode    BroadcastParseMode?
  mediaFileId  String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  logs         KeywordReplyLog[]

  @@index([isActive])
  @@index([keyword])
  @@map("keyword_replies")
}

model KeywordReplyLog {
  id              Int           @id @default(autoincrement())
  keywordReplyId  Int
  telegramGroupId Int
  userTelegramId  BigInt
  messageId       Int
  matchedText     String
  createdAt       DateTime      @default(now())
  keywordReply    KeywordReply  @relation(fields: [keywordReplyId], references: [id], onDelete: Cascade)
  telegramGroup   TelegramGroup @relation(fields: [telegramGroupId], references: [id], onDelete: Cascade)

  @@index([keywordReplyId])
  @@index([telegramGroupId])
  @@index([createdAt])
  @@map("keyword_reply_logs")
}

model BotAdmin {
  id         Int            @id @default(autoincrement())
  telegramId BigInt         @unique
  username   String?
  firstName  String?
  lastName   String?
  role       BotAdminRole   @default(ADMIN)
  status         BotAdminStatus @default(ACTIVE)
  receiveTickets Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([role])
  @@map("bot_admins")
}

model MiniAppDebugLog {
  id         Int      @id @default(autoincrement())
  telegramId BigInt?
  eventType  String
  message    String
  payload    Json?
  userAgent  String?
  createdAt  DateTime @default(now())
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])

  @@index([telegramId])
  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("mini_app_debug_logs")
}

model SystemLog {
  id         Int             @id @default(autoincrement())
  eventType  SystemEventType
  level      SystemLogLevel  @default(INFO)
  message    String
  userId     Int?
  telegramId BigInt?
  metadata   Json?
  createdAt  DateTime        @default(now())
  user       User?           @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([level])
  @@index([userId])
  @@index([telegramId])
  @@index([createdAt])
  @@map("system_logs")
}

model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  email        String?   @unique
  firstName    String?
  lastName     String?
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}

model ScoringSettings {
  id                       Int      @id @default(1)
  startPoints              Int      @default(0)
  channelJoinPoints        Int      @default(0)
  futureActivityPoints     Int      @default(0)
  dailyActivityPoints      Int      @default(5)
  linkClickPoints          Int      @default(2)
  referralRewardPoints     Int      @default(20)
  welcomeMessageText       String   @default("سلام {name} عزیز! 👋\n\n🎯 به ربات کدهای تخفیف پراپ فرم خوش آمدید\n\nاز منوی زیر انتخاب کنید:")
  initialPointsMessageText String   @default("🎁 {points} امتیاز اولیه به حساب شما اضافه شد.")
  isWelcomeMessageEnabled  Boolean  @default(true)
  startOnlyMode            Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  profileCompletionPoints  Int      @default(50)

  @@map("scoring_settings")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model ForcedMembershipSettings {
  id                  Int      @id @default(1)
  enabled             Boolean  @default(true)
  channelId           String   @default("")
  helpMessage         String   @default("برای استفاده از ربات باید عضو کانال ما باشید.\n\nلطفاً در کانال زیر عضو شده و دکمه بررسی را بزنید.")
  joinButtonText      String   @default("عضویت در کانال")
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
  checkButtonText     String   @default("✅ عضو شدم، بررسی کن")
  instructionText     String   @default("لطفاً در کانال(های) زیر عضو شده و دکمه بررسی را بزنید.")
  leaveWarningMessage String   @default("❌ شما کانال را ترک کردید. لطفاً دوباره عضو شوید.")
  notJoinedMessage    String   @default("⚠️ برای استفاده از ربات باید ابتدا در کانال زیر عضو شوید.")
  checkingMessage     String   @default("در حال بررسی عضویت شما...")
  verifiedMessage     String   @default("✅ عضویت شما تایید شد. حالا می‌توانید از امکانات ربات استفاده کنید.")
  welcomeBackMessage  String   @default("✅ خوش آمدید! عضویت شما تایید شد و اکنون می‌توانید از ربات استفاده کنید.")

  @@map("forced_membership_settings")
}

model ForceJoinSettings {
  id                        Int      @id @default(1)
  title                     String   @default("عضویت اجباری")
  welcomeMessage            String   @default("برای استفاده از ربات ابتدا در کانال‌های زیر عضو شوید")
  notJoinedMessage          String   @default("هنوز در همه کانال‌ها عضو نشده‌اید")
  joinButtonText            String   @default("عضویت")
  checkMembershipButtonText String   @default("بررسی عضویت")
  successJoinMessage        String   @default("عضویت شما تایید شد ✅")
  errorMessage              String   @default("خطا در بررسی عضویت")
  retryMessage              String   @default("دوباره تلاش کنید")
  emptyChannelsMessage      String   @default("فعلاً کانالی تعریف نشده است")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("force_join_settings")
}

model MenuOrder {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  label      String
  href       String
  order      Int
  isActive   Boolean  @default(true)
  ownerOnly  Boolean  @default(false)
  featureKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([order])
  @@map("menu_orders")
}

model FeatureToggle {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  description String?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_toggles")
}

model Post {
  id              Int            @id @default(autoincrement())
  title           String
  slug            String         @unique
  content         String?
  caption         String?
  mediaFileId     String?
  mediaType       String?
  mediaFileUniqueId String?      @map("media_file_unique_id")
  mediaCaption    String?        @map("media_caption")
  mediaMimeType   String?        @map("media_mime_type")
  mediaMeta       Json?          @map("media_meta")
  albumMediaIds   Json?
  replyMessageType  String?      @map("reply_message_type")
  replyMessageText  String?      @map("reply_message_text")
  replyMediaFileId  String?      @map("reply_media_file_id")
  replyMediaType   String?       @map("reply_media_type")
  isForwarded      Boolean       @default(false) @map("is_forwarded")
  forwardMeta      Json?         @map("forward_meta")
  forwardSourceChatId  BigInt?   @map("forward_source_chat_id")
  forwardSourceMessageId Int?    @map("forward_source_message_id")
  parseMode       String?        @default("Markdown")
  buttons         Json?
  entities                Json?
  telegramPayload         Json?
  telegramMessageSnapshot Json?
  contentFormat           String?
  contentVersion          Int              @default(1)
  command         String?
  isPublished     Boolean        @default(false)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  unpublishAt     DateTime?
  sortOrder       Int            @default(0)
  status          PostStatus     @default(DRAFT)
  createdBy       BigInt?
  updatedBy       BigInt?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  rawContent      String?
  renderedContent String?
  contentText     String?    @map("content_text")
  contentEntities Json?      @map("content_entities")
  renderMode      String?    @default("telegram_entities") @map("render_mode")
  previewText     String?    @map("preview_text")
  postButtons     PostButton[]
  clickLogs       PostClickLog[]
  commands        PostCommand[]
  versions        PostVersion[]
  views           PostView[]
  richMedia       PostMedia[]
  richEntities    PostEntity[]
  attachments     PostAttachment[]
  keyboards       PostKeyboard[]
  messages        PostMessage[]

  @@index([status])
  @@index([isPublished])
  @@index([slug])
  @@index([sortOrder])
  @@map("posts")
}

model PostMessage {
  id              Int                  @id @default(autoincrement())
  postId          Int                  @map("post_id")
  order           Int
  messageType     PostMessageType      @default(text) @map("message_type")
  text            String?
  entities        Json                 @default("[]")
  parseMode       PostMessageParseMode @default(None) @map("parse_mode")
  mediaFileId     String?              @map("media_file_id")
  mediaGroupId    String?              @map("media_group_id")
  caption         String?
  captionEntities Json                 @default("[]") @map("caption_entities")
  replyMarkup     Json?                @map("reply_markup")
  delayMs         Int                  @default(0) @map("delay_ms")
  forwardSource   Json?                @map("forward_source")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  post            Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  keyboards        PostKeyboard[]

  @@unique([postId, order])
  @@index([postId])
  @@map("post_messages")
}

model PostMedia {
  id              Int      @id @default(autoincrement())
  postId          Int
  type            String
  fileId          String
  fileUniqueId    String?
  mediaGroupId    String?
  caption         String?
  captionEntities Json?
  width           Int?
  height          Int?
  duration        Int?
  fileName        String?
  mimeType        String?
  fileSize        Int?
  thumbnailFileId String?
  order           Int      @default(0)
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([mediaGroupId])
  @@map("post_media")
}

model PostEntity {
  id            Int      @id @default(autoincrement())
  postId        Int
  source        String   @default("text")
  type          String
  offset        Int
  length        Int
  url           String?
  user          Json?
  language      String?
  customEmojiId String?
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([type])
  @@map("post_entities")
}

model PostAttachment {
  id        Int      @id @default(autoincrement())
  postId    Int
  type      String
  fileId    String?
  url       String?
  name      String?
  payload   Json?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

model PostKeyboard {
  id        Int         @id @default(autoincrement())
  postId    Int
  messageId Int?
  row       Int         @default(0)
  col       Int         @default(0)
  text      String
  type      String
  value     String?
  payload   Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  post      Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  message   PostMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([messageId])
  @@map("post_keyboards")
}

model PostButton {
  id        Int            @id @default(autoincrement())
  postId    Int
  row       Int            @default(0)
  col       Int            @default(0)
  text      String
  type      PostButtonType @default(URL)
  value     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_buttons")
}

model PostCommand {
  id        Int      @id @default(autoincrement())
  postId    Int
  command   String   @unique
  aliases   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([command])
  @@map("post_commands")
}

model PostView {
  id         Int      @id @default(autoincrement())
  postId     Int
  userId     Int?
  telegramId BigInt?
  action     String   @default("view")
  metadata   Json?
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("post_views")
}

model PostClickLog {
  id         Int      @id @default(autoincrement())
  postId     Int
  userId     Int?
  telegramId BigInt?
  buttonText String?
  buttonType String?
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_click_logs")
}

model PostVersion {
  id        Int      @id @default(autoincrement())
  postId    Int
  snapshot  Json
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
  @@map("post_versions")
}

